.container { padding: 10rpx; }
.search-bar { padding: 20rpx; }
.search-bar input { 
  background: white; 
  padding: 10rpx 20rpx; 
  border-radius: 50rpx; 
  width: 100%; 
}
.snack-list { padding: 0 20rpx; }
.snack-item { 
  display: flex; 
  background: white; 
  margin-bottom: 20rpx; 
  border-radius: 20rpx; 
  overflow: hidden; 
}
.thumb { width: 180rpx; height: 180rpx; }
.info { padding: 20rpx; flex: 1; }
.name { font-weight: bold; font-size: 32rpx; display: block; }
.brand { color: #666; font-size: 28rpx; display: block; margin: 10rpx 0; }
.tastes text { font-size: 24rpx; color: #888; margin-right: 20rpx; }
.rec-level { 
  margin-top: 10rpx; 
  color: #e94d36; 
  font-weight: bold; 
}
.empty { text-align: center; margin-top: 100rpx; color: #999; }

/* 底部导航样式 - 只显示上传按钮 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: white;
  border-top: 1rpx solid #eee;
  display: flex;
  padding-top: 10rpx;
  padding-bottom: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
}

.upload-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 40rpx;
  background: #ff6b6b;
  color: white;
  border-radius: 40rpx;
  height: 70rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.4);
}

.upload-btn:active {
  background: #e55a5a;
  transform: scale(0.98);
}

.upload-btn .nav-text {
  color: white;
  font-size: 32rpx;
  font-weight: 500;
}

/* 评价按钮样式 */
.rate-btn {
  margin-left: 20rpx;
  background: #ff6b6b;
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
}

.rate-btn::after {
  border: none;
}