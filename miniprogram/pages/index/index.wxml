<!-- miniprogram/pages/index/index.wxml -->
<view class="container">
  <view class="search-bar">
    <input 
      placeholder="搜索零食名称" 
      value="{{keyword}}" 
      bindinput="onSearchInput" 
      confirm-type="search"
    />
  </view>

  <view class="snack-list">
    <view wx:for="{{snackList}}" wx:key="_id" class="snack-item">
      <!-- 左侧：图片+信息 -->
      <image src="{{item.imageUrl || '/images/default-goods-image.png'}}" mode="aspectFill" class="thumb" bindtap="goDetail" data-id="{{item._id}}" />
      <view class="info" bindtap="goDetail" data-id="{{item._id}}">
        <text class="name">{{item.name}}</text>
        <text class="brand">品牌：{{item.brand}}</text>
        <view class="tastes">
          <text wx:for="{{item.tasteDisplay}}" wx:key="index">{{item2}}</text>
        </view>
        <text class="rec-level">{{item.recLevel}}</text>
      </view>
      
      <!-- 右侧：评价按钮 -->
      <button class="rate-btn" size="mini" bindtap="goRate" data-id="{{item._id}}">评价</button>
    </view>

    <view wx:if="{{snackList.length === 0}}" class="empty">
      暂无零食数据
    </view>
  </view>

  <!-- 底部固定导航 - 只有上传按钮 -->
  <view class="bottom-nav">
    <view class="nav-item upload-btn" bindtap="goUpload">
      <text class="nav-text">上传</text>
    </view>
  </view>
</view>