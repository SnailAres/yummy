.cover {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

.score {
  margin-top: 8rpx;
  color: #92400e;
  font-weight: 600;
}

.summary {
  margin-top: 12rpx;
  line-height: 1.6;
}

.reasons {
  margin-top: 10rpx;
}

.reason {
  margin-top: 6rpx;
  color: #374151;
}

.price-row {
  margin-top: 14rpx;
}

.price {
  font-size: 30rpx;
  font-weight: 700;
  color: #b45309;
}

.action-row {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.review-card {
  margin-top: 20rpx;
}

.review-item {
  border-bottom: 1rpx solid #f3f4f6;
  padding: 14rpx 0;
}

.review-content {
  margin-bottom: 6rpx;
}
