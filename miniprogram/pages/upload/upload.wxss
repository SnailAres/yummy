/* pages/upload/upload.wxss */
.container {
  padding: 30rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.field {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.field text {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.field input {
  font-size: 28rpx;
  color: #666;
}

.taste-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.taste-row text {
  width: 80rpx;
  margin-bottom: 0;
}

.taste-row radio-group {
  flex: 1;
  display: flex;
  align-items: center;
}

.taste-row label {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
}

.upload-area {
  background: white;
  padding: 60rpx;
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx dashed #ddd;
  margin-bottom: 20rpx;
}

.upload-area text {
  font-size: 28rpx;
  color: #999;
}

.upload-area image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
}

.upload-area:active {
  background: #f5f5f5;
}

slider {
  width: 100%;
  margin-top: 20rpx;
}

.submit-btn {
  margin-top: 40rpx;
  border-radius: 40rpx;
  background: #ff6b6b;
  font-size: 32rpx;
}

.submit-btn::after {
  border: none;
}