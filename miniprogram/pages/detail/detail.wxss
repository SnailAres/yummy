/* miniprogram/pages/detail/detail.wxss */
.back-btn {
  padding: 12rpx 24rpx;
  font-size: 28rpx;
  color: #007aff;
  margin-bottom: 20rpx;
}

.container {
  padding: 20rpx;
  background: #f8f8f8;
}

.big-img {
  width: 100%;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.content {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.brand {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 24rpx;
}

.section {
  margin-bottom: 24rpx;
}

.tastes {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 10rpx;
}

.tastes text {
  background: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #333;
}

.rating-section {
  margin-top: 40rpx;
}

.rating-section button {
  margin-top: 20rpx;
}

.loading {
  text-align: center;
  margin-top: 200rpx;
  color: #999;
  font-size: 28rpx;
}