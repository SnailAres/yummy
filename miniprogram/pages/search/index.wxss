.search-input {
  width: 100%;
  box-sizing: border-box;
  padding: 14rpx;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  background: #ffffff;
}

.sort-row {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
}

.sort-item {
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 22rpx;
}

.sort-item.active {
  background: #111827;
  color: #ffffff;
}

.total {
  margin: 16rpx 0;
}
